{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.61.84.121:5000/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://13.61.84.121:5000/uploads/:path*"
    },
    {
      "source": "/Postes/:path*",
      "destination": "http://13.61.84.121:5000/Postes/:path*"
    },
    {
      "source": "/video-player/Postes/:path*",
      "destination": "http://13.61.84.121:5000/Postes/:path*"
    },
    {
      "source": "/img/:path*",
      "destination": "http://13.61.84.121:5000/img/:path*"
    },
    {
      "source": "/AMovies-Poster/:path*",
      "destination": "http://13.61.84.121:5000/AMovies-Poster/:path*"
    },
    {
      "source": "/Horror-poster/:path*",
      "destination": "http://13.61.84.121:5000/Horror-poster/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/Posts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "image/jpeg"
        }
      ]
    },
    {
      "source": "/AMovies-Poster/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/Horror-poster/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(jpg|jpeg|png|gif|webp|svg|ico|css|js))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}